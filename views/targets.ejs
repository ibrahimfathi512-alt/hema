<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Target Analysis | Tanta Car Elite</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --tanta-orange: #ff5e00;
            --main-dark: #0c0c0e;
            --card-bg: rgba(23, 23, 26, 0.7);
            --border-color: rgba(255, 255, 255, 0.08);
            --text-muted: #a1a1aa;
            --success: #22c55e;
            --warning: #f1c40f;
            --danger: #ef4444;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            background-color: var(--main-dark);
            background-image: 
                radial-gradient(circle at 10% 10%, rgba(255, 94, 0, 0.07) 0%, transparent 35%),
                radial-gradient(circle at 90% 90%, rgba(255, 94, 0, 0.03) 0%, transparent 35%);
            color: #ffffff;
            font-family: 'Cairo', sans-serif;
            margin: 0;
            padding: 20px 40px;
            min-height: 100vh;
            line-height: 1.6;
        }

        /* Nav Bar */
        .nav-header {
            background: var(--card-bg);
            backdrop-filter: blur(15px);
            border: 1px solid var(--border-color);
            padding: 15px 30px;
            border-radius: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .nav-header h2 { 
            margin: 0; 
            font-size: 20px; 
            font-weight: 900; 
            letter-spacing: 0.5px;
        }

        .back-btn {
            text-decoration: none;
            color: #fff;
            background: rgba(255, 255, 255, 0.05);
            padding: 8px 18px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: var(--transition);
            border: 1px solid var(--border-color);
        }

        .back-btn:hover { 
            background: var(--tanta-orange);
            transform: scale(1.05);
            border-color: var(--tanta-orange);
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 25px;
            border-radius: 24px;
            position: relative;
            overflow: hidden;
            transition: var(--transition);
        }

        .stat-card:hover { 
            border-color: rgba(255, 94, 0, 0.4); 
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.4);
        }

        .stat-card h4 { 
            color: var(--text-muted); 
            margin: 0; 
            font-size: 13px; 
            text-transform: uppercase; 
            font-weight: 600;
        }

        .stat-card h2 { 
            margin: 15px 0 5px 0; 
            font-size: 34px; 
            font-weight: 900; 
            color: #fff;
        }

        .stat-card i {
            position: absolute;
            left: -10px;
            bottom: -10px;
            font-size: 80px;
            opacity: 0.05;
            color: var(--tanta-orange);
            transform: rotate(-15deg);
        }

        /* Table Design */
        .table-container {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            overflow: hidden;
            backdrop-filter: blur(10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        table { width: 100%; border-collapse: collapse; }
        
        th {
            background: rgba(255,255,255,0.03);
            color: var(--tanta-orange);
            padding: 20px;
            text-align: center;
            font-size: 14px;
            font-weight: 700;
            border-bottom: 2px solid var(--border-color);
        }

        td { 
            padding: 20px; 
            text-align: center; 
            border-bottom: 1px solid rgba(255,255,255,0.03); 
            font-weight: 600;
            color: #e4e4e7;
        }

        tr:hover td {
            background: rgba(255, 255, 255, 0.02);
            color: #fff;
        }

        /* Progress Bar */
        .progress-wrapper { 
            width: 160px; 
            margin: 0 auto; 
        }

        .progress-bar {
            height: 8px;
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            overflow: hidden;
            margin-top: 8px;
        }

        .progress-fill { 
            height: 100%; 
            border-radius: 20px; 
            transition: width 1.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        }

        /* Badges */
        .badge {
            padding: 8px 16px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-width: 120px;
            justify-content: center;
        }

        .bg-excellent { 
            background: rgba(34, 197, 94, 0.1); 
            color: var(--success); 
            border: 1px solid rgba(34, 197, 94, 0.2); 
            box-shadow: 0 0 15px rgba(34, 197, 94, 0.1);
        }
        
        .bg-good { 
            background: rgba(241, 196, 15, 0.1); 
            color: var(--warning); 
            border: 1px solid rgba(241, 196, 15, 0.2); 
        }
        
        .bg-poor { 
            background: rgba(239, 68, 68, 0.1); 
            color: var(--danger); 
            border: 1px solid rgba(239, 68, 68, 0.2); 
        }

        .glow-text-success { 
            text-shadow: 0 0 20px rgba(34, 197, 94, 0.5); 
            color: var(--success); 
        }

        /* Responsive */
        @media (max-width: 768px) {
            body { padding: 15px; }
            .nav-header { flex-direction: column; gap: 15px; text-align: center; }
            .stats-grid { grid-template-columns: 1fr; }
            .table-container { overflow-x: auto; }
        }
    </style>
</head>
<body>

    <div class="nav-header">
        <div style="display: flex; align-items: center; gap: 15px;">
            <div style="width: 12px; height: 12px; border-radius: 50%; background: var(--tanta-orange); box-shadow: 0 0 15px var(--tanta-orange);"></div>
            <h2>تحليل أداء الزون: <span style="color: var(--tanta-orange);"><%= zone %></span></h2>
        </div>
        <a href="/dashboard" class="back-btn">
            <span>العودة للرئيسية</span>
            <i class="fa-solid fa-arrow-left-long"></i>
        </a>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <i class="fa-solid fa-bullseye"></i>
            <h4>التارجت المطلوب</h4>
            <h2><%= cleanData(zoneData.get('normal Target')) %> <small style="font-size: 14px; color: var(--text-muted);">ساعة</small></h2>
        </div>

        <div class="stat-card">
            <i class="fa-solid fa-chart-line"></i>
            <h4>المتوسط الحالي</h4>
            <h2><%= cleanData(zoneData.get('Average')) %> <small style="font-size: 14px; color: var(--text-muted);">ساعة</small></h2>
        </div>

        <div class="stat-card" style="border-bottom: 4px solid var(--success);">
            <i class="fa-solid fa-gauge-high" style="color: var(--success); opacity: 0.1;"></i>
            <h4>نسبة التحقيق الإجمالية</h4>
            <h2 class="glow-text-success"><%= zoneData.get('Average %') %></h2>
        </div>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th><i class="fa-regular fa-calendar-days" style="margin-left: 8px;"></i>التاريخ</th>
                    <th><i class="fa-regular fa-clock" style="margin-left: 8px;"></i>الساعات المحققة</th>
                    <th><i class="fa-solid fa-chart-pie" style="margin-left: 8px;"></i>نسبة الإنجاز</th>
                    <th><i class="fa-solid fa-ranking-star" style="margin-left: 8px;"></i>حالة الأداء اليومي</th>
                </tr>
            </thead>
            <tbody>
                <% headers.forEach(h => { 
                    if(h.includes('/')) { 
                        let val = cleanData(zoneData.get(h));
                        let target = cleanData(zoneData.get('normal Target'));
                        let pct = (target > 0) ? (val / target * 100) : 0;
                        
                        let badgeClass = '';
                        let barColor = '';
                        let statusText = '';
                        let icon = '';

                        if (pct >= 95) { 
                            badgeClass = 'bg-excellent'; barColor = 'var(--success)'; 
                            statusText = 'أداء استثنائي'; icon = 'fa-crown'; 
                        }
                        else if (pct >= 85) { 
                            badgeClass = 'bg-excellent'; barColor = 'var(--success)'; 
                            statusText = 'عاش يا بطل'; icon = 'fa-trophy'; 
                        }
                        else if (pct >= 70) { 
                            badgeClass = 'bg-good'; barColor = 'var(--warning)'; 
                            statusText = 'أداء مستقر'; icon = 'fa-star'; 
                        }
                        else { 
                            badgeClass = 'bg-poor'; barColor = 'var(--danger)'; 
                            statusText = 'يحتاج تحسين'; icon = 'fa-triangle-exclamation'; 
                        }
                %>
                <tr>
                    <td style="color: var(--text-muted); font-family: 'monospace'; letter-spacing: 1px;"><%= h %></td>
                    <td style="font-size: 18px; color: #fff;"><%= val %> <small style="font-size: 11px; color: var(--text-muted);">HR</small></td>
                    <td>
                        <div class="progress-wrapper">
                            <div style="display:flex; justify-content:space-between; font-size: 12px; margin-bottom: 6px;">
                                <span style="font-weight: 700;"><%= pct.toFixed(1) %>%</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: <%= Math.min(pct, 100) %>%; background: <%= barColor %>; box-shadow: 0 0 10px <%= barColor %>88;"></div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="badge <%= badgeClass %>">
                            <i class="fa-solid <%= icon %>"></i>
                            <%= statusText %>
                        </span>
                    </td>
                </tr>
                <% } }); %>
            </tbody>
        </table>
    </div>

    <footer style="margin-top: 50px; padding-bottom: 20px; text-align: center; color: var(--text-muted); font-size: 11px; text-transform: uppercase; letter-spacing: 2px; opacity: 0.6;">
        <i class="fa-solid fa-shield-halved" style="margin-left: 5px;"></i> 
        Tanta Car Fleet Analytics // Internal System v2.6 // 2024
    </footer>

</body>
</html>